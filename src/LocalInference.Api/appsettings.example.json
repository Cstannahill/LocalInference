{
  // Logging Configuration
  // Controls the verbosity and categories of logs output
  "Logging": {
    "LogLevel": {
      // Default log level for all categories not explicitly configured
      "Default": "Information",

      // Log levels: Trace, Debug, Information, Warning, Error, Critical, None
      // Trace = Most verbose, None = No logging

      // ASP.NET Core framework logging (usually set to Warning to reduce noise)
      "Microsoft.AspNetCore": "Warning",

      // Entity Framework Core - useful for debugging database issues
      "Microsoft.EntityFrameworkCore": "Warning",

      // EF Core SQL command logging (very verbose, for debugging)
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",

      // HTTP client logging (for debugging inference provider calls)
      "System.Net.Http.HttpClient": "Warning",

      // Your application logs
      "LocalInference": "Information"
    }
  },

  // Security: List of allowed hosts (comma-separated or array in JSON)
  // Set to "*" to allow all hosts (development), restrict in production
  "AllowedHosts": "*",

  // Database Connection Strings
  "ConnectionStrings": {
    // Primary database connection
    // Format: Host=<server>;Database=<database>;Username=<user>;Password=<password>;Port=<port>;SslMode=Require
    // For PostgreSQL:
    //   - Remove Port=5432 to use default (5432)
    //   - SslMode options: Disable, Allow, Prefer, Require
    //   - For local development: SslMode=Disable
    //   - For production: SslMode=Require
    "DefaultConnection": "Host=localhost;Database=LocalInference;Username=postgres;Password=your_secure_password_here;Port=5432;SslMode=Disable"
  },

  // Inference Configuration
  // Settings for LLM inference providers
  "Inference": {
    // Ollama Configuration (for local LLM inference)
    "Ollama": {
      // Base URL where Ollama is running
      // Local development: http://localhost:11434
      // Docker: http://ollama:11434
      // Remote: http://<your-ollama-host>:11434
      "BaseUrl": "http://localhost:11434"

      // Optional: Timeout for Ollama API calls (milliseconds)
      // "Timeout": 300000

      // Optional: HTTP version for Ollama requests
      // "HttpVersion": "1.1"
    },

    // OpenRouter Configuration (for cloud-based inference)
    // Sign up at https://openrouter.ai and generate an API key
    "OpenRouter": {
      // Your OpenRouter API key - starts with "sk-or-v1-"
      // Store in environment variable: Inference__OpenRouter__ApiKey
      "ApiKey": "sk-or-v1-your_openrouter_api_key_here"

      // Optional: Whether to include reasoning in tokens
      // "IncludeReasoning": false
    }
  },

  // ASP.NET Core Kestrel Server Configuration
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000",
        "Protocols": "Http1AndHttp2"
      },
      "Https": {
        "Url": "https://localhost:5001",
        "Protocols": "Http1AndHttp2"
        // Uncomment and configure for production HTTPS
        // "Certificate": {
        //   "Path": "/path/to/certificate.pfx",
        //   "Password": "certificate_password"
        // }
      }
    }
  }

  // Optional: CORS Configuration (if needed)
  // "Cors": {
  //   "AllowedOrigins": [
  //     "http://localhost:3000",
  //     "https://yourdomain.com"
  //   ],
  //   "AllowedMethods": ["GET", "POST", "PUT", "DELETE"],
  //   "AllowedHeaders": ["*"],
  //   "AllowCredentials": true
  // },

  // Optional: Session Configuration
  // "Session": {
  //   "CookieSecure": true,
  //   "CookieHttpOnly": true,
  //   "CookieSameSite": "Lax"
  // },

  // Optional: JWT Authentication (if implementing auth)
  // "Authentication": {
  //   "Jwt": {
  //     "SecretKey": "your_super_long_secret_key_with_at_least_32_characters",
  //     "Issuer": "YourAppName",
  //     "Audience": "YourAppAudience",
  //     "ExpirationMinutes": 60
  //   }
  // }
}
